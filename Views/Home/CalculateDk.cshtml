@model AspKnP231.Models.Home.DkViewModel
@{
    ViewData["Title"] = "Обчислення DK";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>
    <hr />

    <div class="row">
        <div class="col-md-5">
            <form asp-action="CalculateDk" method="post" class="card p-4 shadow-sm">

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Пароль</label>
                    <input asp-for="Password" class="form-control" type="text" required />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Salt" class="form-label">Сіль (Salt)</label>
                    <input asp-for="Salt" class="form-control" type="text" id="saltInput" />
                </div>

                <div class="form-check mb-4">
                    <input asp-for="AutoGenerateSalt" class="form-check-input" type="checkbox" id="autoSaltCheck" onchange="toggleSaltInput()" />
                    <label asp-for="AutoGenerateSalt" class="form-check-label">
                        Згенерувати сіль автоматично
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100">Обчислити DK</button>
            </form>
        </div>

        <div class="col-md-7">
            @if (!string.IsNullOrEmpty(Model?.ResultDk))
            {
            <div class="alert alert-success shadow-sm h-100">
                <h4 class="alert-heading">Результат обчислення:</h4>
                <hr>
                <p class="mb-2"><strong>Використана сіль:</strong> <code>@Model.Salt</code></p>
                <p class="mb-0"><strong>Отриманий Derived Key:</strong></p>
                <div class="bg-white p-2 mt-2 border rounded text-break font-monospace">
                    @Model.ResultDk
                </div>
            </div>
            }
        </div>
    </div>
</div>

<script>

    function toggleSaltInput() {
        var checkBox = document.getElementById("autoSaltCheck");
        var saltInput = document.getElementById("saltInput");
        if (checkBox.checked) {
            saltInput.disabled = true;
            saltInput.value = "";
        } else {
            saltInput.disabled = false;
        }
    }
</script>